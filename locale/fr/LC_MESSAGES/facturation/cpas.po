msgid "Action"
msgstr "Action"

#: ../../content/facturation/cpas.md:118
msgid "Automatic?"
msgstr "Automatique ?"

#: ../../content/facturation/cpas.md:118
msgid "Track the CPAS decision (financial audit)"
msgstr "Tracer la décision CPAS (audit financier)"

#: ../../content/facturation/cpas.md:118
msgid "Yes, as soon as it's entered"
msgstr "Oui, dès la saisie"

#: ../../content/facturation/cpas.md:118
msgid "Switch the **Default payer** to CPAS when you tick \"Covered by CPAS\""
msgstr ""
"Basculer le **Payeur par défaut** sur CPAS quand vous cochez « Pris en "
"charge CPAS »"

#: ../../content/facturation/cpas.md:118
msgid "Yes"
msgstr "Oui"

#: ../../content/facturation/cpas.md:118
