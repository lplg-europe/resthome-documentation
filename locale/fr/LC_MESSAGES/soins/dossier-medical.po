#: ../../content/soins/dossier-medical.md:81
#: ../../content/soins/dossier-medical.md:141
msgid "**Severity**"
msgstr "**Sévérité**"

#: ../../content/soins/dossier-medical.md:81
msgid "Mild · Moderate · Severe — specific to this resident"
msgstr "Léger · Modéré · Sévère — propre à ce résident"

#: ../../content/soins/dossier-medical.md:81
msgid "**Status**"
msgstr "**Statut**"

#: ../../content/soins/dossier-medical.md:81
msgid "**Active** or **Resolved**"
msgstr "**Actif** ou **Résolu**"

#: ../../content/soins/dossier-medical.md:81
#: ../../content/soins/dossier-medical.md:141
msgid "**Confirmed**"
msgstr "**Confirmé**"

#: ../../content/soins/dossier-medical.md:81
msgid "Clinically confirmed diagnosis (yes / no)"
msgstr "Diagnostic cliniquement confirmé (oui / non)"

#: ../../content/soins/dossier-medical.md:81
#: ../../content/soins/dossier-medical.md:141
msgid "**Date**"
msgstr "**Date**"

#: ../../content/soins/dossier-medical.md:81
msgid "Date of diagnosis"
msgstr "Date du diagnostic"

#: ../../content/soins/dossier-medical.md:81
msgid "**Notes**"
msgstr "**Notes**"

#: ../../content/soins/dossier-medical.md:81
msgid "Clinical observations"
