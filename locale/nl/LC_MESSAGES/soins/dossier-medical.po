msgstr "Zelfstandig · Stok · Looprek · Rolstoel · Bedlegerig"

#: ../../content/soins/dossier-medical.md:81
msgid "**Continence**"
msgstr "**Continentie**"

#: ../../content/soins/dossier-medical.md:81
msgid ""
"Continent · Occasional Incontinence · Frequent Incontinence · Incontinent"
msgstr ""
"Continent · Occasionele incontinentie · Frequente incontinentie · "
"Incontinent"

#: ../../content/soins/dossier-medical.md:81
msgid "**Cognitive Status**"
msgstr "**Cognitieve status**"

#: ../../content/soins/dossier-medical.md:81
