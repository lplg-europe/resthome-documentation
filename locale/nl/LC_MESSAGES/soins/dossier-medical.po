#: ../../content/soins/dossier-medical.md:81
msgid "Yes / No"
msgstr "Ja / Nee"

#: ../../content/soins/dossier-medical.md:81
msgid "**Pressure Sore Risk**"
msgstr "**Doorligwonden risico**"

#: ../../content/soins/dossier-medical.md:81
msgid "Low · Moderate · High"
