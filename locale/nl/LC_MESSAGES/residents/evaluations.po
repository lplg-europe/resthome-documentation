#: ../../content/residents/evaluations.md:160
msgid "Total: /28"
msgstr "Totaal: /28"

#: ../../content/residents/evaluations.md:162
msgid "Resthome calculates the two subscores and the total."
msgstr "Resthome berekent de twee subscores en het totaal."

