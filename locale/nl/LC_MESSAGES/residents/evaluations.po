msgstr "9-16"

#: ../../content/residents/evaluations.md:122
msgid "Unhealthy (urgent referral)"
msgstr "Ongezond (dringende verwijzing)"

#: ../../content/residents/evaluations.md:146
msgid "« N/A » options"
